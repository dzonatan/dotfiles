theme = gruvbox
font-size = 16
macos-option-as-alt = true

split-divider-color = #d5c4a1
unfocused-split-opacity = 0.5

window-padding-x = 10,20

# tmux like keymaps
keybind = ctrl+a>l=goto_split:right
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>z=toggle_split_zoom
keybind = ctrl+z=toggle_split_zoom
keybind = ctrl+a>v=write_screen_file:open
keybind = ctrl+alt+l=goto_split:right
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:bottom
keybind = ctrl+alt+k=goto_split:top
keybind = shift+enter=text:\n
keybind = cmd+ctrl+l=goto_split:right
keybind = cmd+ctrl+h=goto_split:left
keybind = cmd+ctrl+j=goto_split:bottom
keybind = cmd+ctrl+k=goto_split:top

# scroll up/down
keybind = page_up=scroll_page_lines:-5
keybind = page_down=scroll_page_lines:5
keybind = home=scroll_to_top
keybind = end=scroll_to_bottom
