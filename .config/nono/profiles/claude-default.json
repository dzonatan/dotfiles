{
  "extends": "claude-code",
  "meta": { "name": "claude-ng" },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.npm/_logs",
      "$HOME/.npm/_npx",
      "$HOME/.npm/_cacache",
      "$HOME/.cache/chrome-devtools-mcp/chrome-profile"
    ],
    "read": [
      "$HOME/.npm-packages",
      "$HOME/.npm",
      "/run",
      "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
    ],
    "allow_file": ["$HOME/.claude/settings.json", "$HOME/.angular-config.json"],
    "read_file": ["$HOME/.npmrc", "$HOME/.claude/statusline.sh"]
  },
  "network": { "block": false },
  "workdir": { "access": "readwrite" },
  "undo": {
    "exclude_patterns": ["node_modules", ".next", "__pycache__", "target"],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "policy": {
    "override_deny": ["$HOME/.npmrc"]
  },
  "interactive": true
}
