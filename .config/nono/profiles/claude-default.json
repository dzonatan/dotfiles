{
  "extends": "claude-code",
  "meta": { "name": "claude-ng" },
  "filesystem": {
    "allow": ["$WORKDIR"],
    "read": ["$HOME/.npm-packages", "$HOME/.npm"],
    "allow_file": ["$HOME/.claude/settings.json", "$HOME/.angular-config.json"],
    "read_file": [
      "$HOME/.npmrc",
      "$HOME/.claude/statusline.sh"
    ]
  },
  "network": { "block": false },
  "workdir": { "access": "readwrite" },
  "undo": {
    "exclude_patterns": ["node_modules", ".next", "__pycache__", "target"],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "interactive": true
}
