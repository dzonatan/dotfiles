{
  "meta": { "name": "pi" },
  "security": {
    "groups": ["git_config"]
  },
  "network": {
    "block": false
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.npm/_logs",
      "$HOME/.npm/_npx",
      "$HOME/.npm/_cacache",
      "$HOME/.cache/chrome-devtools-mcp/chrome-profile",
      "$HOME/.pi/"
    ],
    "read": [
      "$HOME/.npm-packages",
      "$HOME/.npm",
      "$HOME/Library/pnpm/",
      "/run"
    ],
    "allow_file": [
      "$HOME/.angular-config.json",
      "$HOME/.pi/agent/settings.json"
    ],
    "read_file": [
      "$HOME/.npmrc",
      "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
    ]
  },
  "policy": {
    "override_deny": ["$HOME/.npmrc"],
    "exclude_groups": ["dangerous_commands"]
  }
}
